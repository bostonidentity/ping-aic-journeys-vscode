{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "out",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src/**/*", "tests/**/*"],
  "exclude": [
    "src/webview/inspector/ui/**",
    "tests/webview/inspector/ui/**",
    "src/webview/connection-form/ui/**",
    "tests/webview/connection-form/ui/**",
    "src/webview/search/ui/**",
    "tests/webview/search/ui/**",
    "src/webview/transfer/ui/**",
    "tests/webview/transfer/ui/**",
    "src/webview/shared/**",
    "tests/webview/shared/**"
  ]
}
