{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!node_modules",
      "!out",
      "!coverage",
      "!tests/fixtures",
      "!poc",
      "!ref",
      "!.claude"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all",
      "arrowParentheses": "always"
    }
  },
  "linter": {
    "enabled": true,
    "domains": {
      "test": "recommended"
    },
    "rules": {
      "recommended": true,

      "correctness": {
        "noUnusedImports": "error",
        "noUnusedVariables": "error",
        "noUnusedFunctionParameters": "warn",
        "noConstAssign": "error",
        "noPrecisionLoss": "error",
        "noUndeclaredVariables": "error",
        "noInvalidUseBeforeDeclaration": "error",
        "noSelfAssign": "error",
        "noSwitchDeclarations": "error",
        "noVoidTypeReturn": "error",
        "useImportExtensions": "off"
      },

      "suspicious": {
        "noExplicitAny": "warn",
        "noImplicitAnyLet": "warn",
        "noDoubleEquals": "error",
        "noDebugger": "error",
        "noConsole": {
          "level": "warn",
          "options": {
            "allow": ["error", "warn", "info"]
          }
        },
        "noFallthroughSwitchClause": "error",
        "noRedeclare": "error",
        "noShadowRestrictedNames": "error",
        "noEmptyBlockStatements": "warn",
        "noEvolvingTypes": "warn",
        "noThenProperty": "error",
        "noVar": "error",
        "useAwait": "error",
        "useErrorMessage": "error",
        "useIsArray": "error"
      },

      "complexity": {
        "noForEach": "warn",
        "noStaticOnlyClass": "error",
        "noUselessCatch": "error",
        "noUselessConstructor": "error",
        "noUselessEmptyExport": "error",
        "noUselessTernary": "error",
        "noUselessTypeConstraint": "error",
        "useOptionalChain": "error",
        "useFlatMap": "warn",
        "useArrowFunction": "warn",
        "noExcessiveCognitiveComplexity": {
          "level": "warn",
          "options": { "maxAllowedComplexity": 25 }
        }
      },

      "performance": {
        "noAccumulatingSpread": "warn",
        "noDelete": "warn",
        "noBarrelFile": "warn"
      },

      "security": {
        "noGlobalEval": "error",
        "noSecrets": "error"
      },

      "style": {
        "useConst": "error",
        "useTemplate": "error",
        "useExportType": "error",
        "useImportType": "error",
        "useNodejsImportProtocol": "error",
        "useSingleVarDeclarator": "error",
        "useDefaultParameterLast": "error",
        "useExponentiationOperator": "error",
        "useShorthandAssign": "error",
        "useThrowNewError": "error",
        "useThrowOnlyError": "error",
        "noNonNullAssertion": "warn",
        "noNegationElse": "warn",
        "noNestedTernary": "error",
        "noCommonJs": "error",
        "useFilenamingConvention": {
          "level": "error",
          "options": { "requireAscii": true, "filenameCases": ["kebab-case", "export"] }
        },
        "useNamingConvention": {
          "level": "warn",
          "options": {
            "strictCase": false,
            "conventions": [
              { "selector": { "kind": "function" }, "formats": ["camelCase", "PascalCase"] },
              {
                "selector": { "kind": "variable" },
                "formats": ["camelCase", "CONSTANT_CASE", "PascalCase"]
              },
              { "selector": { "kind": "typeLike" }, "formats": ["PascalCase"] },
              {
                "selector": { "kind": "objectLiteralProperty" },
                "formats": ["camelCase", "snake_case", "CONSTANT_CASE", "PascalCase"]
              },
              { "selector": { "kind": "typeProperty" }, "formats": ["camelCase", "snake_case"] }
            ]
          }
        }
      },

      "nursery": {
        "noFloatingPromises": "error",
        "noShadow": "warn",
        "useAwaitThenable": "off",
        "useErrorCause": "warn"
      }
    }
  },
  "assist": {
    "enabled": true
  },
  "overrides": [
    {
      "includes": ["**/*.test.ts", "tests/**"],
      "linter": {
        "rules": {
          "security": {
            "noSecrets": "off"
          }
        }
      }
    },
    {
      "includes": ["src/extension.ts"],
      "linter": {
        "rules": {
          "style": {
            "useFilenamingConvention": "off"
          }
        }
      }
    }
  ]
}
