{
  "name": "ping-aic-journeys",
  "displayName": "PAIC Journeys",
  "description": "Browse and analyze PAIC journey dependencies from VS Code.",
  "version": "0.1.1",
  "preview": true,
  "publisher": "BostonIdentity",
  "license": "MIT",
  "icon": "media/icon.png",
  "categories": [
    "Visualization"
  ],
  "keywords": [
    "ping",
    "paic",
    "ping identity",
    "advanced identity cloud",
    "forgerock",
    "journey",
    "authentication tree",
    "identity"
  ],
  "galleryBanner": {
    "color": "#0f172a",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bostonidentity/ping-aic-journeys-vscode.git"
  },
  "bugs": {
    "url": "https://github.com/bostonidentity/ping-aic-journeys-vscode/issues"
  },
  "homepage": "https://github.com/bostonidentity/ping-aic-journeys-vscode#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./out/extension.js",
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "paicJourneys",
          "title": "PAIC Journeys",
          "icon": "$(type-hierarchy)"
        }
      ]
    },
    "views": {
      "paicJourneys": [
        {
          "id": "paicJourneys.connections",
          "name": "Connections"
        }
      ]
    },
    "commands": [
      {
        "command": "paicJourneys.addConnection",
        "title": "Add Connection",
        "icon": "$(add)"
      },
      {
        "command": "paicJourneys.editConnection",
        "title": "Edit Connection",
        "icon": "$(edit)"
      },
      {
        "command": "paicJourneys.removeConnection",
        "title": "Remove Connection",
        "icon": "$(trash)"
      },
      {
        "command": "paicJourneys.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "paicJourneys.refreshNode",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "paicJourneys.openScriptBody",
        "title": "Open Script Body",
        "icon": "$(go-to-file)"
      },
      {
        "command": "paicJourneys.openSearch",
        "title": "PAIC: Search…",
        "icon": "$(search)"
      },
      {
        "command": "paicJourneys.findUsages",
        "title": "PAIC: Find Usages…",
        "icon": "$(search)"
      },
      {
        "command": "paicJourneys.exportComponent",
        "title": "Export Component",
        "icon": "$(export)"
      },
      {
        "command": "paicJourneys.exportJourney",
        "title": "Export Journey",
        "icon": "$(export)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "paicJourneys.openScriptBody",
          "when": "false"
        },
        {
          "command": "paicJourneys.refreshNode",
          "when": "false"
        },
        {
          "command": "paicJourneys.findUsages",
          "when": "false"
        },
        {
          "command": "paicJourneys.exportComponent",
          "when": "false"
        },
        {
          "command": "paicJourneys.exportJourney",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "paicJourneys.addConnection",
          "when": "view == paicJourneys.connections",
          "group": "navigation@1"
        },
        {
          "command": "paicJourneys.openSearch",
          "when": "view == paicJourneys.connections",
          "group": "navigation@2"
        },
        {
          "command": "paicJourneys.refresh",
          "when": "view == paicJourneys.connections",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "paicJourneys.refreshNode",
          "when": "view == paicJourneys.connections && viewItem =~ /^(connection|realm|journey|innerJourney)$/",
          "group": "inline@1"
        },
        {
          "command": "paicJourneys.openScriptBody",
          "when": "view == paicJourneys.connections && viewItem =~ /^(script|libraryScript)$/",
          "group": "inline@1"
        },
        {
          "command": "paicJourneys.openScriptBody",
          "when": "view == paicJourneys.connections && viewItem =~ /^(script|libraryScript)$/",
          "group": "1@1"
        },
        {
          "command": "paicJourneys.editConnection",
          "when": "view == paicJourneys.connections && viewItem == connection",
          "group": "inline@2"
        },
        {
          "command": "paicJourneys.removeConnection",
          "when": "view == paicJourneys.connections && viewItem == connection",
          "group": "inline@3"
        },
        {
          "command": "paicJourneys.editConnection",
          "when": "view == paicJourneys.connections && viewItem == connection",
          "group": "1@1"
        },
        {
          "command": "paicJourneys.removeConnection",
          "when": "view == paicJourneys.connections && viewItem == connection",
          "group": "9@1"
        },
        {
          "command": "paicJourneys.openSearch",
          "when": "view == paicJourneys.connections && viewItem == connection",
          "group": "1@2"
        },
        {
          "command": "paicJourneys.openSearch",
          "when": "view == paicJourneys.connections && viewItem == realm",
          "group": "1@1"
        }
      ]
    },
    "configuration": {
      "title": "PAIC Journeys",
      "properties": {
        "paicJourneys.connections": {
          "type": "array",
          "scope": "application",
          "default": [],
          "description": "Connections (per-user). PAIC cloud (kind=paic): host + saId, secret is the service-account JWK. On-prem PingAM (kind=onprem): host = base URL, username, secret is the admin password. The secret is stored in SecretStorage, not here. Application-scoped: workspace-level overrides are ignored by VS Code.",
          "items": {
            "type": "object",
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "paic",
                  "onprem"
                ],
                "description": "Connection type. Omitted entries are treated as 'paic' (legacy)."
              },
              "host": {
                "type": "string"
              },
              "saId": {
                "type": "string",
                "description": "PAIC service-account id (kind=paic)."
              },
              "username": {
                "type": "string",
                "description": "On-prem admin username (kind=onprem)."
              },
              "name": {
                "type": "string"
              }
            }
          }
        },
        "paicJourneys.logging.level": {
          "type": "string",
          "scope": "application",
          "enum": [
            "fatal",
            "error",
            "warn",
            "info",
            "debug",
            "trace"
          ],
          "default": "info",
          "description": "Minimum log level emitted by the extension. Per-user (application-scoped): workspace-level overrides are ignored."
        },
        "paicJourneys.logging.fileEnabled": {
          "type": "boolean",
          "scope": "application",
          "default": true,
          "description": "Write structured NDJSON logs to globalStorageUri/logs/paic-journeys.ndjson for log shippers (Vector, Filebeat, Promtail, etc.). The VS Code Output panel always reflects logs regardless of this setting. Per-user (application-scoped): workspace-level overrides are ignored."
        }
      }
    }
  },
  "scripts": {
    "build:ext": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --platform=node --format=cjs",
    "build:webview": "esbuild src/webview/inspector/ui/main.tsx --bundle --outfile=out/webview.js --platform=browser --format=iife --jsx=automatic --define:process.env.NODE_ENV=\"\\\"production\\\"\"",
    "build:connection-form": "esbuild src/webview/connection-form/ui/main.tsx --bundle --outfile=out/connection-form.js --platform=browser --format=iife --jsx=automatic --define:process.env.NODE_ENV=\"\\\"production\\\"\"",
    "build:search": "esbuild src/webview/search/ui/main.tsx --bundle --outfile=out/search.js --platform=browser --format=iife --jsx=automatic --define:process.env.NODE_ENV=\"\\\"production\\\"\"",
    "build:codicons": "mkdir -p out && cp node_modules/@vscode/codicons/dist/codicon.css out/codicon.css && cp node_modules/@vscode/codicons/dist/codicon.ttf out/codicon.ttf",
    "build": "npm run build:ext && npm run build:webview && npm run build:connection-form && npm run build:search && npm run build:codicons",
    "watch": "npm run build:ext -- --watch",
    "watch:webview": "npm run build:webview -- --watch",
    "watch:connection-form": "npm run build:connection-form -- --watch",
    "watch:search": "npm run build:search -- --watch",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.webview.json --noEmit",
    "test": "vitest run",
    "test:fast": "vitest run --exclude '**/*.integration.test.ts'",
    "vscode:prepublish": "npm run build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/dagre": "^0.7.54",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/vscode": "^1.85.0",
    "@vscode/codicons": "^0.0.45",
    "@vscode/vsce": "^3.9.1",
    "axios-mock-adapter": "^2.1.0",
    "esbuild": "^0.21.0",
    "happy-dom": "^20.9.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "axios-retry": "^4.5.0",
    "dagre": "^0.8.5",
    "jose": "^6.2.3",
    "pino": "^10.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reactflow": "^11.11.4"
  }
}
